---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import toolsData from '../../data/tools.json';

export async function getStaticPaths() {
  return toolsData.map((tool) => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;

// Similar tools (same category, different tool)
const similarTools = toolsData
  .filter(t => t.category === tool.category && t.id !== tool.id)
  .slice(0, 3);
---

<Layout 
  title={`${tool.name} İncelemesi | Yapaylar ${tool.category} Araçları`}
  description={tool.tagline}
  url={`https://yapaylar.com/tools/${tool.id}`}
  type="website"
>
  <Header client:load />

  <div class="bg-neutral-50 min-h-screen pb-24">
    <!-- Breadcrumb -->
    <div class="pt-4 md:pt-6 mb-4 md:mb-6">
      <div class="max-w-[1200px] mx-auto px-4 md:px-6 sm:px-8 lg:px-12 flex items-center gap-2 text-[13px] sm:text-sm">
        <a href="/" class="inline-flex items-center gap-1.5 text-neutral-500 hover:text-neutral-900 transition-colors font-semibold bg-white md:bg-transparent px-3 py-1.5 md:p-0 rounded-lg md:rounded-none border border-neutral-200 md:border-transparent shadow-sm md:shadow-none">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          <span class="hidden md:inline">Keşfet (Anasayfa)</span>
          <span class="md:hidden">Anasayfa</span>
        </a>
        <span class="hidden md:inline text-neutral-300">/</span>
        <span class="hidden md:inline text-neutral-800 font-semibold truncate">{tool.name}</span>
      </div>
    </div>

    <div class="max-w-[1200px] mx-auto px-4 md:px-6 sm:px-8 lg:px-12">
      <!-- Main Hero Card -->
      <div class="bg-white rounded-3xl border border-neutral-200 shadow-sm p-8 md:p-10 mb-10 overflow-hidden relative">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-50 rounded-bl-full opacity-60 pointer-events-none -mr-10 -mt-10"></div>
        
        <div class="flex flex-col md:flex-row md:items-start gap-8 relative z-10">
          <div class="w-32 h-32 rounded-[2rem] bg-neutral-50 border border-neutral-100 flex items-center justify-center text-6xl flex-shrink-0 shadow-sm">
            {tool.emoji}
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-neutral-100 text-neutral-600 rounded-full text-[12px] font-bold tracking-wide uppercase">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                </svg>
                {tool.category}
              </span>
              {tool.pricing && (
                <span class="inline-flex items-center px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-[12px] font-bold tracking-wide uppercase">
                  {tool.pricing === 'freemium' ? 'Freemium' : tool.pricing === 'free' ? 'Ücretsiz' : 'Ücretli'}
                </span>
              )}
            </div>

            <h1 class="text-3xl md:text-5xl font-extrabold text-neutral-900 tracking-tight mb-3">
              {tool.name}
            </h1>
            <p class="text-[17px] md:text-xl text-neutral-500 leading-relaxed max-w-2xl mb-6">
              {tool.tagline}
            </p>
            
            <div class="flex flex-wrap items-center gap-2 mb-8">
              {tool.tags?.map((tag: string) => (
                <span class="text-xs font-medium text-neutral-500 bg-neutral-100 border border-neutral-200/60 px-2.5 py-1 rounded-md">
                  {tag}
                </span>
              ))}
            </div>

            <div class="flex items-center gap-4">
              <a
                href="#"
                class="inline-flex items-center justify-center h-12 md:h-14 px-8 rounded-xl bg-blue-600 text-white text-[15px] font-bold hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-600/20 transition-all duration-200"
              >
                Uygulamaya Git
                <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
              <span class="text-neutral-400 font-medium text-sm flex items-center gap-1.5 px-4 py-2 border border-neutral-200 rounded-xl bg-neutral-50">
                <svg class="w-4 h-4 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                {tool.votes} Oy
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Content Column -->
        <div class="lg:col-span-2 flex flex-col gap-10">
          
          <!-- About -->
          <section>
            <h2 class="text-2xl font-extrabold text-neutral-900 tracking-tight mb-4 flex items-center gap-2">
              Bilinmesi Gerekenler
            </h2>
            <div class="bg-white rounded-2xl p-6 md:p-8 border border-neutral-200 shadow-sm">
              <p class="text-[16px] text-neutral-600 leading-relaxed">
                <strong class="text-neutral-900">{tool.name}</strong>, günümüz teknolojisinde <span class="font-medium text-blue-600">{tool.category.toLowerCase()}</span> alanındaki en yetenekli yapay zeka araçlarından biri olarak öne çıkıyor. Modern AI altyapısı kullanarak hazırlanan algoritmalar sayesinde kullanıcılarına oldukça kaliteli, hızlı ve güvenilir çıktılar üretir. Kullanması kolaydır ve ister profesyonel ister amatör iş akışlarında yaratıcılığınızı doğrudan artırır.
              </p>
            </div>
          </section>

          <!-- Features Grid -->
          <section>
            <h2 class="text-2xl font-extrabold text-neutral-900 tracking-tight mb-4">
              Öne Çıkan Yetenekler
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { icon: '⚡', title: 'Işık Hızında Üretim', desc: 'Sisteme gönderdiğiniz sorgular saniyeler içerisinde tamamlanıp ekranınıza yansır.' },
                { icon: '🎯', title: 'Yüksek Doğruluk Derecesi', desc: 'En güncel dil/görsel modelleriyle akılcı ve sınırları zorlayan sonuçlar alırsınız.' },
                { icon: '🔒', title: 'Tam Korumalı Veriler', desc: 'Yarattığınız metinler ve görseller gelişmiş şifrelemeyle sunucularda korunur.' },
                { icon: '🌍', title: 'Türkçe Anlama', desc: 'Yerel dildeki tüm ince esprileri, deyimleri ve spesifik kalıpları harika anlar.' },
              ].map((feature) => (
                <div class="flex items-start gap-4 p-5 bg-white rounded-2xl border border-neutral-200 shadow-sm hover:border-blue-200 hover:shadow-md transition-all">
                  <div class="w-12 h-12 rounded-xl bg-neutral-50 flex items-center justify-center text-xl flex-shrink-0 shadow-sm border border-neutral-100">
                    {feature.icon}
                  </div>
                  <div class="pt-0.5">
                    <h3 class="text-[14px] font-bold text-neutral-900 mb-1">
                      {feature.title}
                    </h3>
                    <p class="text-[13px] text-neutral-500 leading-relaxed">
                      {feature.desc}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        </div>

        <!-- Sidebar -->
        <div class="flex flex-col gap-10">
          
          <!-- Pricing -->
          <section>
            <h2 class="text-lg font-bold text-neutral-900 tracking-tight mb-4">Plan & Ücretlendirme</h2>
            <div class="flex flex-col gap-3">
              {[
                { plan: 'Başlangıç (Basic)', desc: 'Keşfetmek için ideal plan', price: '$0', featured: tool.pricing === 'free' || tool.pricing === 'freemium' },
                { plan: 'Kişisel (Pro)', desc: 'Profesyoneller için sınırsız erişim', price: '$20/ay', featured: tool.pricing === 'paid' },
                { plan: 'Kurumsal (Enterprise)', desc: 'Ekipler için ortak çalışma', price: 'Özel', featured: false }
              ].map((p, i) => (
                <div class={`rounded-xl p-4 border ${p.featured ? 'bg-blue-50/50 border-blue-200' : 'bg-white border-neutral-200'}`}>
                  <div class="flex items-start justify-between">
                    <div>
                      <h3 class={`text-[14px] font-bold ${p.featured ? 'text-blue-900' : 'text-neutral-900'}`}>{p.plan}</h3>
                      <p class={`text-[12px] mt-0.5 ${p.featured ? 'text-blue-700/80' : 'text-neutral-500'}`}>{p.desc}</p>
                    </div>
                    <span class={`font-extrabold ${p.featured ? 'text-blue-700' : 'text-neutral-900'}`}>{p.price}</span>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- Similar Tools -->
          {similarTools.length > 0 && (
            <section>
              <h2 class="text-lg font-bold text-neutral-900 tracking-tight mb-4 flex items-center justify-between">
                Benzer Alternatifler
                <span class="text-xs bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full">{similarTools.length}</span>
              </h2>
              <div class="flex flex-col gap-3">
                {similarTools.map((similar) => (
                  <a
                    href={`/tools/${similar.id}`}
                    class="group flex items-center gap-4 bg-white rounded-xl border border-neutral-200 p-3 hover:shadow-sm hover:border-neutral-300 transition-all duration-200"
                  >
                    <div class="w-12 h-12 rounded-lg bg-neutral-50 border border-neutral-100 flex items-center justify-center text-xl flex-shrink-0">
                      {similar.emoji}
                    </div>
                    <div>
                      <h3 class="text-[14px] font-bold text-neutral-900 group-hover:text-blue-600 transition-colors duration-150">
                        {similar.name}
                      </h3>
                      <p class="text-[12px] text-neutral-500 mt-0.5">
                        {similar.category} Aracı
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )}

        </div>
      </div>
    </div>
  </div>
  
  <Footer client:load />
</Layout>
