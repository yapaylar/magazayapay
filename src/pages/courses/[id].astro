---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import coursesData from '../../data/courses.json';

export async function getStaticPaths() {
  return coursesData.map((course) => ({
    params: { id: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;
const completed = course.lessons.filter((l: any) => l.completed).length;
const total = course.lessons.length;
const progress = Math.round((completed / total) * 100);
---

<Layout 
  title={`${course.title} - Yapaylar Akademi`}
  description={course.description}
  url={`https://yapaylar.com/courses/${course.id}`}
  type="article"
>
  <Header client:load />
  
  <div class="bg-neutral-50 min-h-screen pb-20 pt-6">
    <!-- Breadcrumb -->
    <div class="mb-4 pt-4 md:pt-0">
      <div class="max-w-[1400px] mx-auto px-4 md:px-6 sm:px-8 lg:px-12 flex items-center gap-2 text-[13px] sm:text-sm">
        <a href="/learn" class="inline-flex items-center gap-1.5 text-neutral-500 hover:text-neutral-900 transition-colors font-semibold bg-white md:bg-transparent px-3 py-1.5 md:p-0 rounded-lg md:rounded-none border border-neutral-200 md:border-transparent shadow-sm md:shadow-none">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          <span class="hidden md:inline">Akademi</span>
          <span class="md:hidden">Geri Dön</span>
        </a>
        <span class="hidden md:inline text-neutral-300">/</span>
        <span class="hidden md:inline text-neutral-800 font-semibold truncate">{course.title}</span>
      </div>
    </div>

    <!-- Main Dual-Column LMS Content -->
    <div class="max-w-[1400px] mx-auto px-4 md:px-6 sm:px-8 lg:px-12 pb-8 lg:grid lg:grid-cols-[1fr_400px] gap-10 items-start">
      
      <!-- MAIN COLUMN: VIDEO & INFO -->
      <div class="flex flex-col gap-6 md:gap-8">
        <!-- Video Player -->
        <div class="aspect-video w-full rounded-2xl bg-black shadow-xl overflow-hidden relative border border-neutral-200/50" id="video-container">
          {course.lessons[0] && course.lessons[0].vimeoId ? (
            <iframe 
              id="lesson-iframe"
              src={`https://player.vimeo.com/video/${course.lessons[0].vimeoId}?title=0&byline=0&portrait=0`}
              class="absolute top-0 left-0 w-full h-full"
              frameborder="0" 
              allow="autoplay; fullscreen; picture-in-picture" 
              allowfullscreen>
            </iframe>
          ) : (
            <div id="video-placeholder" class="w-full h-full flex items-center justify-center bg-neutral-100">
              <span class="text-7xl drop-shadow-sm">{course.emoji}</span>
            </div>
          )}
        </div>

        <!-- Course Details -->
        <div class="bg-white rounded-2xl p-6 md:p-8 border border-neutral-200 shadow-sm">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <span class="text-[12px] font-bold text-blue-700 bg-blue-50 px-3 py-1 rounded-full uppercase tracking-wider">
              {course.level}
            </span>
            <span class="text-[12px] font-bold text-green-700 bg-green-50 px-3 py-1 rounded-full uppercase tracking-wider">
              ÜCRETSİZ
            </span>
            <span class="text-[12px] font-bold text-neutral-600 bg-neutral-100 px-3 py-1 rounded-full uppercase tracking-wider">
              {course.duration}
            </span>
          </div>
          <h1 class="text-2xl md:text-3xl lg:text-4xl font-extrabold text-neutral-900 leading-tight mb-4">{course.title}</h1>
          

          <h3 class="text-xl font-bold text-neutral-900 mb-4">Eğitim Hakkında</h3>
          <p class="text-neutral-600 leading-relaxed text-[15px]">{course.description}</p>
        </div>
      </div>

      <!-- SIDEBAR: LESSONS & PROGRESS -->
      <div class="lg:sticky lg:top-8 flex flex-col gap-6 mt-8 lg:mt-0">
        
        <!-- Progress Card -->
        {completed > 0 && (
          <div class="bg-white p-6 rounded-2xl border border-neutral-200 shadow-sm">
            <div class="flex items-center justify-between text-sm mb-3">
              <span class="font-semibold text-neutral-700">İlerleme Durumu</span>
              <span class="font-bold text-blue-600">{completed}/{total} Ders</span>
            </div>
            <div class="h-2.5 rounded-full bg-neutral-100 overflow-hidden">
              <div class="h-full rounded-full bg-blue-500 transition-all duration-500" style={`width: ${progress}%`} />
            </div>
            <p class="text-xs text-neutral-400 mt-3 font-medium">Platformdaki yolculuğunuza devam edin!</p>
          </div>
        )}

        <!-- Lessons List -->
        <div class="bg-white rounded-2xl border border-neutral-200 shadow-sm overflow-hidden flex flex-col max-h-[800px] lg:max-h-[calc(100vh-120px)]">
          <div class="p-5 border-b border-neutral-100 bg-neutral-50/50">
            <h2 class="text-lg font-bold text-neutral-900 flex items-center justify-between">
              Eğitim İçeriği
              <span class="bg-neutral-200 text-neutral-600 text-xs px-2 py-0.5 rounded-full font-bold">{total} Ders</span>
            </h2>
          </div>
          
          <div class="overflow-y-auto flex-1 custom-scrollbar">
            <div class="divide-y divide-neutral-100 pb-4">
              {course.lessons.map((lesson: any, i: number) => {
                const isFirstInUnit = i === 0 || lesson.unit !== course.lessons[i - 1].unit;
                const isCurrent = !lesson.completed && (i === 0 || course.lessons[i - 1]?.completed);
                return (
                  <>
                    {/* Unit Header */}
                    {isFirstInUnit && lesson.unit && (
                      <div class="bg-neutral-50/95 backdrop-blur-md px-5 py-3 text-[11px] font-extrabold text-neutral-500 uppercase tracking-wider sticky top-0 z-10 border-b border-neutral-100 shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
                        {lesson.unit}
                      </div>
                    )}
                    
                    {/* Lesson Button */}
                    <button 
                      class={`w-full group flex flex-col gap-2 px-5 py-4 text-left transition-all duration-200 lesson-btn ${isCurrent ? 'bg-blue-50/50 active-lesson' : 'hover:bg-neutral-50'}`}
                      data-vimeo-id={lesson.vimeoId}
                    >
                      <div class="flex items-start gap-3 w-full">
                        {/* Status indicator */}
                        <div class={`w-6 h-6 mt-0.5 rounded-full flex items-center justify-center flex-shrink-0 text-[10px] font-bold transition-colors ${
                          lesson.completed
                            ? 'bg-green-100 text-green-600'
                            : isCurrent
                              ? 'bg-blue-600 text-white shadow-md shadow-blue-500/20'
                              : 'bg-neutral-100 text-neutral-400 group-hover:bg-neutral-200 group-hover:text-neutral-600'
                        }`}>
                          {lesson.completed ? (
                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                              <polyline points="20 6 9 17 4 12" />
                            </svg>
                          ) : isCurrent ? (
                            <svg class="w-2.5 h-2.5 ml-0.5 fill-white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                          ) : (
                            <span>{i + 1}</span>
                          )}
                        </div>

                        {/* Title and Duration Info */}
                        <div class="flex-1 min-w-0 pr-2">
                          <p class={`text-[13px] font-semibold leading-snug transition-colors ${lesson.completed ? 'text-neutral-400 line-through' : isCurrent ? 'text-blue-700' : 'text-neutral-700 group-hover:text-neutral-900'}`}>
                            {lesson.title}
                          </p>
                          <div class="flex items-center gap-2 mt-2 opacity-80">
                            <span class="text-[10px] text-neutral-500 flex items-center gap-1 font-medium bg-neutral-100 px-1.5 py-0.5 rounded">
                              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                              {lesson.duration === '00:00' ? 'Video' : lesson.duration}
                            </span>
                          </div>
                        </div>
                      </div>
                    </button>
                  </>
                );
              })}
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
  <Footer client:load />
</Layout>

<style>
/* Custom minimal scrollbar for the sidebar */
.custom-scrollbar::-webkit-scrollbar {
  width: 5px;
}
.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}
.custom-scrollbar::-webkit-scrollbar-thumb {
  background-color: #e5e5e5;
  border-radius: 10px;
}
.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background-color: #d4d4d4;
}
</style>

<script>
  // Script to handle lesson video switching
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.lesson-btn');
    const iframe = document.getElementById('lesson-iframe') as HTMLIFrameElement | null;

    if (!iframe) return;

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const vimeoId = btn.getAttribute('data-vimeo-id');
        
        if (vimeoId) {
          // Update iframe src with autoplay
          iframe.src = `https://player.vimeo.com/video/${vimeoId}?title=0&byline=0&portrait=0&autoplay=1`;
          
          // Reset all buttons visual state
          buttons.forEach((b) => {
            b.classList.remove('bg-blue-50/50', 'active-lesson');
            b.classList.add('hover:bg-neutral-50');
            
            // Revert active text/icon styling
            const iconDiv = b.querySelector('.w-6.h-6');
            if (iconDiv && iconDiv.classList.contains('bg-blue-600')) {
                iconDiv.classList.remove('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-500/20');
                iconDiv.classList.add('bg-neutral-100', 'text-neutral-400', 'group-hover:bg-neutral-200', 'group-hover:text-neutral-600');
                
                // Switch play icon back to number if needed (approximated for UX)
                const playIcon = iconDiv.querySelector('svg');
                if (playIcon) playIcon.style.opacity = '0.5';
            }

            const titleP = b.querySelector('p');
            if(titleP && !titleP.classList.contains('line-through')) {
               titleP.classList.remove('text-blue-700');
               titleP.classList.add('text-neutral-700', 'group-hover:text-neutral-900');
            }
          });
          
          // Set new active button visual state
          btn.classList.remove('hover:bg-neutral-50');
          btn.classList.add('bg-blue-50/50', 'active-lesson');
          
          const iconDiv = btn.querySelector('.w-6.h-6');
          if (iconDiv && !iconDiv.classList.contains('bg-green-100')) {
             iconDiv.classList.remove('bg-neutral-100', 'text-neutral-400', 'group-hover:bg-neutral-200', 'group-hover:text-neutral-600');
             iconDiv.classList.add('bg-blue-600', 'text-white', 'shadow-md', 'shadow-blue-500/20');
             const svg = iconDiv.querySelector('svg');
             if (svg) svg.style.opacity = '1';
          }

          const titleP = btn.querySelector('p');
          if(titleP && !titleP.classList.contains('line-through')) {
             titleP.classList.remove('text-neutral-700', 'group-hover:text-neutral-900');
             titleP.classList.add('text-blue-700');
          }
        }
      });
    });
  });
</script>

